# Build artifacts
/output/
.claude/

# Exported images (regeneratable)
*.drawio.png
*.drawio.svg
*.drawio.pdf

# Preview PNG exports (regeneratable)
.drawio/*
# But keep source files (editable)
!.drawio/*.mmd
!.drawio/*.drawio

# Draw.io backup files (anywhere)
**/.$*.bkp

# Python
**/__pycache__/
*.pyc
.pytest_cache/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Claude Code session memory
/memory/

# Test temp files
/tmp/

# Temp workspace (Feishu doc backups etc.)
/.tmp/
