# Build artifacts
/output/
.claude/

# Exported images (regeneratable)
*.drawio.png
*.drawio.svg
*.drawio.pdf

# Preview PNG exports (regeneratable)
.drawio/*
!.drawio/type/
!.drawio/type/*.mmd
!.drawio/type/*.drawio

# Draw.io backup files (anywhere)
**/.$*.bkp

# Python
**/__pycache__/
*.pyc
.pytest_cache/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Claude Code session memory
/memory/

# Test temp files
/tmp/
