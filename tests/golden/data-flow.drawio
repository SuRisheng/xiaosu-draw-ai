        <!-- Process 3: Aggregate -->
        <mxCell id="7" value="&lt;b&gt;3. 数据聚合&lt;/b&gt;&lt;br&gt;按小时/天计算销售额和销量" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
