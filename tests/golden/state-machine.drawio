<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0" type="device">
  <diagram name="Order Lifecycle State Machine" id="sm-1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="Order Lifecycle — State Machine" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="20" width="280" height="30" as="geometry" />
        </mxCell>

        <!-- Initial state -->
        <mxCell id="3" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="20" height="20" as="geometry" />
        </mxCell>

        <!-- State: Pending Payment -->
        <mxCell id="4" value="&lt;b&gt;待支付&lt;/b&gt;&lt;br&gt;Pending Payment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="100" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- State: Paid -->
        <mxCell id="5" value="&lt;b&gt;已支付&lt;/b&gt;&lt;br&gt;Paid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="100" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- State: Shipped -->
        <mxCell id="6" value="&lt;b&gt;已发货&lt;/b&gt;&lt;br&gt;Shipped" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="100" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- State: Completed (final) -->
        <mxCell id="7" value="&lt;b&gt;已完成&lt;/b&gt;&lt;br&gt;Completed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="780" y="100" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- State: Cancelled (final, error) -->
        <mxCell id="8" value="&lt;b&gt;已取消&lt;/b&gt;&lt;br&gt;Cancelled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="300" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- State: Refunding -->
        <mxCell id="9" value="&lt;b&gt;退款中&lt;/b&gt;&lt;br&gt;Refunding" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="300" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Edges -->

        <!-- Initial → Pending Payment -->
        <mxCell id="10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="3" target="4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Pending Payment → Paid: pay success -->
        <mxCell id="11" value="支付成功 / pay()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="4" target="5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Pending Payment → Cancelled: timeout -->
        <mxCell id="12" value="超时 [30 min] / cancel()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;dashPattern=8 4;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="4" target="8">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="190" y="180" />
              <mxPoint x="340" y="180" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Paid → Shipped: ship -->
        <mxCell id="13" value="仓库发货 / ship()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="5" target="6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Paid → Refunding: refund requested -->
        <mxCell id="14" value="用户申请退款 / refund()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;dashPattern=8 4;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="5" target="9">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="410" y="180" />
              <mxPoint x="630" y="180" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Shipped → Completed: confirm -->
        <mxCell id="15" value="确认收货 / confirm()&lt;br&gt;或 7 天自动确认" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="6" target="7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Refunding → Cancelled: refund complete -->
        <mxCell id="16" value="退款完成 / complete()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="9" target="8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
